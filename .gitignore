# =========================
# ENV FILES (VERY IMPORTANT)
# =========================
.env
.env.*
!env.example

# =========================
# PYTHON (Backend)
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc
*.pkl

.venv/
venv/
env/
*.example
*.egg-info/
dist/
build/

.mypy_cache/
.pytest_cache/
.ruff_cache/

# FastAPI / SQLAlchemy / Alembic
alembic/versions/*.pyc
alembic/__pycache__/

# =========================
# NODE (Frontend)
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

dist/
build/
.vite/

# =========================
# DOCKER
# =========================
*.log

# Docker volumes (if accidentally created locally)
postgres-data/
pgdata/
redis-data/

# =========================
